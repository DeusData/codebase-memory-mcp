{
  "version": 1,
  "language": "gdscript",
  "promotion_target": "good",
  "approval_contract": {
    "approval_mode": "manifest-only",
    "canonical_identity_fields": [
      "remote",
      "pinned_commit",
      "project_subpath",
      "godot_version"
    ],
    "label_role": "readability-only",
    "local_checkout_path_role": "run-evidence-only",
    "ad_hoc_repo_runs": {
      "allowed": true,
      "canonical": false,
      "qualifies_for_v1": false,
      "purpose": "debugging-or-investigation"
    },
    "qualification_rule": {
      "requires_recorded_godot_4x": true,
      "non_4x_or_unknown_status": "non-qualifying"
    }
  },
  "minimum_repo_count": 3,
  "repos": [
    {
      "label": "squash-the-creeps",
      "remote": "https://github.com/godotengine/godot-demo-projects.git",
      "project_subpath": "3d/squash_the_creeps",
      "pinned_commit": "87c1fb6dafa5ceaedf97a2ce5d00ce7bf83a5b76",
      "godot_version": "4.2",
      "canonicality": "canonical-approved-v1-target",
      "qualification": {
        "status": "godot-4.x-qualified",
        "qualifies_for_v1": true,
        "basis": "recorded-godot-version"
      },
      "required_for": ["indexing", "signals"],
      "assertions": [
        {
          "id": "indexing.gd-files",
          "query": "gd-files",
          "classification": "gating",
          "expected": {"count": 4}
        },
        {
          "id": "indexing.gd-classes",
          "query": "gd-classes",
          "classification": "gating",
          "expected": {"count": 4}
        },
        {
          "id": "indexing.gd-methods",
          "query": "gd-methods",
          "classification": "gating",
          "expected": {"count": 12}
        },
        {
          "id": "signals.calls",
          "query": "signal-calls",
          "classification": "gating",
          "expected": {
            "count": 2,
            "contains_edges": [
              "Player.gd:die->Player.gd:hit",
              "Mob.gd:squash->Mob.gd:squashed"
            ]
          }
        },
        {
          "id": "methods.sample",
          "query": "gd-method-sample",
          "classification": "informational",
          "expected": {
            "contains": [
              "Main.gd:_ready",
              "Player.gd:die"
            ]
          }
        }
      ]
    },
